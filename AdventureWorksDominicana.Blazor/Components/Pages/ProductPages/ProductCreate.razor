@page "/Product/Create"
@attribute [Authorize(Roles = "Admin, ProductionManager")]

@rendermode InteractiveServer

@inject ProductService productService
@inject ProductSubcategoryService productSubcategoryService
@inject ProductModelService productModelService
@inject UnitMeasureService unitMeasureService
@inject ToastService toastService
@inject NavigationManager navigationManager
@inject SpecialOfferProductService specialOfferProductService
@inject SpecialOfferService specialOfferService
@inject ProductPhotoService photoService

<PageTitle>Crear Producto</PageTitle>

<div class="product-container">
    
    <div class="product-header">
        <div>
            <h3>Crear Producto</h3>
            <span>Registro de nuevos productos en el catálogo</span>
        </div>
    </div>

    <div class="product-form">
        <EditForm Model="Product" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card shadow-lg">
                <div class="card-body">

                    <h5 class="section-title">
                        <i class="bi bi-info-circle"></i> Información General
                    </h5>
                    
                    <div class="mb-3">
                        <label class="form-label"><strong>Nombre</strong></label>
                        <input class="form-control" type="text" @bind="Product.Name" placeholder="Ej: Mountain Bike 1000" />
                        <ValidationMessage For="(() => Product.Name)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Número de producto</strong></label>
                        <input class="form-control" type="text" @bind="Product.ProductNumber" placeholder="Ej: MT-1000" />
                        <ValidationMessage For="(() => Product.ProductNumber)" />
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3 form-check">
                                <input class="form-check-input" type="checkbox" @bind="Product.MakeFlag" id="MakeFlag" />
                                <label class="form-check-label" for="MakeFlag">Fabricación propia</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3 form-check">
                                <input class="form-check-input" type="checkbox" @bind="Product.FinishedGoodsFlag" id="FinishedGoodsFlag" />
                                <label class="form-check-label" for="FinishedGoodsFlag">Producto terminado</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Color</strong></label>
                        <input class="form-control" type="text" @bind="Product.Color" placeholder="Ej: Rojo, Negro" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Tamaño</strong></label>
                        <div class="input-group">
                            <input class="form-control" type="text" @bind="Product.Size" placeholder="Ej: M, L, XL, 58" />
                            <select class="form-select" style="max-width: 100px;" @bind="Product.SizeUnitMeasureCode">
                                <option value="">Unidad</option>
                                @foreach (var u in ListaUnidades)
                                {
                                    <option value="@u.UnitMeasureCode">@u.UnitMeasureCode</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Peso</strong></label>
                        <div class="input-group">
                            <input class="form-control" type="number" step="0.01" @bind="Product.Weight" placeholder="0.00" />
                            <select class="form-select" style="max-width: 100px;" @bind="Product.WeightUnitMeasureCode">
                                <option value="">Unidad</option>
                                @foreach (var u in ListaUnidades)
                                {
                                    <option value="@u.UnitMeasureCode">@u.UnitMeasureCode</option>
                                }
                            </select>
                        </div>
                    </div>

                    <h5 class="section-title mt-4">
                        <i class="bi bi-currency-dollar"></i> Costos y Precios
                    </h5>

                    <div class="mb-3">
                        <label class="form-label"><strong>Costo estándar</strong></label>
                        <div class="input-group">
                            <span class="input-group-text">RD$</span>
                            <input class="form-control" type="number" step="0.01" min="0" @bind="Product.StandardCost" />
                        </div>
                        <ValidationMessage For="(() => Product.StandardCost)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Precio de lista</strong></label>
                        <div class="input-group">
                            <span class="input-group-text">RD$</span>
                            <input class="form-control" type="number" step="0.01" min="0" @bind="Product.ListPrice" />
                        </div>
                        <ValidationMessage For="(() => Product.ListPrice)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Días de fabricación</strong></label>
                        <input class="form-control" type="number" min="0" @bind="Product.DaysToManufacture" />
                        <ValidationMessage For="(() => Product.DaysToManufacture)" />
                    </div>

                    <h5 class="section-title mt-4">
                        <i class="bi bi-box-seam"></i> Inventario
                    </h5>

                    <div class="mb-3">
                        <label class="form-label"><strong>Stock de seguridad</strong></label>
                        <input class="form-control" type="number" min="0" @bind="Product.SafetyStockLevel" />
                        <ValidationMessage For="(() => Product.SafetyStockLevel)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Punto de reorden</strong></label>
                        <input class="form-control" type="number" min="0" @bind="Product.ReorderPoint" />
                        <ValidationMessage For="(() => Product.ReorderPoint)" />
                    </div>

                    <h5 class="section-title mt-4">
                        <i class="bi bi-tags"></i> Clasificación
                    </h5>

                    <div class="mb-3">
                        <label class="form-label"><strong>Línea de producto</strong></label>
                        <select class="form-select" @bind="Product.ProductLine">
                            <option value="">— Seleccione —</option>
                            <option value="R">Road (R)</option>
                            <option value="M">Mountain (M)</option>
                            <option value="T">Touring (T)</option>
                            <option value="S">Standard (S)</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Clase</strong></label>
                        <select class="form-select" @bind="Product.Class">
                            <option value="">— Seleccione —</option>
                            <option value="H">High (H)</option>
                            <option value="M">Medium (M)</option>
                            <option value="L">Low (L)</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Estilo</strong></label>
                        <select class="form-select" @bind="Product.Style">
                            <option value="">— Seleccione —</option>
                            <option value="W">Women's (W)</option>
                            <option value="M">Men's (M)</option>
                            <option value="U">Universal (U)</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Subcategoría</strong></label>
                        <select class="form-select" @bind="Product.ProductSubcategoryId">
                            <option value="">— Ninguna —</option>
                            @foreach (var s in ListaSubcategorias)
                            {
                                <option value="@s.ProductSubcategoryId">@s.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Modelo de producto</strong></label>
                        <select class="form-select" @bind="Product.ProductModelId">
                            <option value="">— Ninguno —</option>
                            @foreach (var m in ListaModelos)
                            {
                                <option value="@m.ProductModelId">@m.Name</option>
                            }
                        </select>
                    </div>

                    <h5 class="section-title mt-4">
                        <i class="bi bi-calendar-event"></i> Fechas
                    </h5>

                    <div class="mb-3">
                        <label class="form-label"><strong>Inicio de venta</strong></label>
                        <input class="form-control" type="datetime-local" @bind="Product.SellStartDate" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Fin de venta</strong></label>
                        <input class="form-control" type="datetime-local" @bind="Product.SellEndDate" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Fecha de descontinuación</strong></label>
                        <input class="form-control" type="datetime-local" @bind="Product.DiscontinuedDate" />
                    </div>

                    <h5 class="section-title mt-4">
                        <i class="bi bi-camera"></i> Fotografía Principal
                    </h5>

                    <div class="row align-items-center">
                        <div class="col-md-4 text-center mb-3 mb-md-0">
                            @if (!string.IsNullOrWhiteSpace(UrlImagenPreview))
                            {
                                <img src="@UrlImagenPreview" class="product-preview-img" />
                            }
                            else
                            {
                                <div class="product-preview-placeholder">
                                    <i class="bi bi-image fs-1 text-muted"></i>
                                    <p class="mb-0 text-muted small">Sin imagen seleccionada</p>
                                </div>
                            }
                        </div>
                        <div class="col-md-8">
                            <label class="form-label"><strong>URL o ruta de imagen</strong></label>
                            <input class="form-control" type="text" @bind="RutaImagenManual" placeholder="Ej: https://sitio.com/imagen.png o iphone.png" />
                            <small class="text-muted mt-2 d-block">Puedes poner una URL completa o un nombre de archivo/ruta guardada.</small>

                            <div class="mt-3 d-flex gap-2">
                                <button type="button" class="btn btn-outline-secondary" @onclick="PrevisualizarRuta">Previsualizar</button>
                                <button type="button" class="btn btn-outline-primary" @onclick="GuardarRutaTemporal">Usar imagen</button>
                            </div>
                        </div>
                    </div>

                    <h5 class="section-title mt-4">
                        <i class="bi bi-percent"></i> Promociones Aplicadas
                    </h5>

                    <div class="border p-3 mb-3">
                        <h5 class="mb-3">Asignar Oferta</h5>
                        <div class="row mb-3">
                            <div class="col-md-9">
                                <select class="form-select" @bind="OfertaSeleccionadaId">
                                    <option value="0">— Seleccione una oferta —</option>
                                    @foreach (var off in TodasLasOfertas)
                                    {
                                        <option value="@off.SpecialOfferId">
                                            @off.Description (@((off.DiscountPct * 100).ToString("N0"))% · hasta @off.EndDate.ToShortDateString())
                                        </option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <button type="button" class="btn btn-primary bi bi-plus" @onclick="AgregarOferta"> Agregar</button>
                            </div>
                        </div>

                        <QuickGrid Items="OfertasSeleccionadas.AsQueryable()" Class="table table-striped table-bordered table-hover">
                            <PropertyColumn Property="@(o => o.Description)" Title="Oferta" />
                            <TemplateColumn Title="Descuento">
                                <ChildContent Context="det">
                                    @((det.DiscountPct * 100).ToString("N0"))%
                                </ChildContent>
                            </TemplateColumn>
                            <PropertyColumn Property="@(o => o.EndDate)" Format="dd/MM/yyyy" Title="Vence" />
                            <TemplateColumn>
                                <ChildContent Context="det">
                                    <button type="button" class="btn btn-outline-dark btn-sm bi bi-trash" @onclick="(() => RemoverOferta(det))"> Eliminar</button>
                                </ChildContent>
                            </TemplateColumn>
                        </QuickGrid>
                    </div>

                    <div class="mt-2 fw-bold">
                        Ofertas a aplicar: @OfertasSeleccionadas.Count
                    </div>

                </div>

                <div class="card-footer text-center">
                    <a class="btn btn-secondary bi bi-arrow-left" href="/Product/Index"> Volver</a>
                    <button class="btn btn-primary bi bi-floppy" type="submit"> Guardar</button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    public Product Product { get; set; } = new();
    public List<ProductSubcategory> ListaSubcategorias { get; set; } = new();
    public List<ProductModel> ListaModelos { get; set; } = new();
    public List<UnitMeasure> ListaUnidades { get; set; } = new();

    public List<SpecialOffer> TodasLasOfertas { get; set; } = new();
    public List<SpecialOffer> OfertasSeleccionadas { get; set; } = new();
    public int OfertaSeleccionadaId { get; set; } = 0;

    private string? UrlImagenPreview;
    private string? RutaImagenManual;
    private string? RutaImagenParaGuardar;

    protected override async Task OnInitializedAsync()
    {
        Product.MakeFlag = true;
        Product.FinishedGoodsFlag = true;
        Product.SafetyStockLevel = 1000;
        Product.ReorderPoint = 750;
        Product.DaysToManufacture = 0;
        Product.StandardCost = 0;
        Product.ListPrice = 0;
        Product.SellStartDate = DateTime.Now;
        Product.ModifiedDate = DateTime.Now;
        Product.Rowguid = Guid.NewGuid();

        ListaSubcategorias = await productSubcategoryService.GetList(s => s.ProductSubcategoryId > 0);
        ListaModelos = await productModelService.GetList(m => m.ProductModelId > 0);
        ListaUnidades = await unitMeasureService.GetList(u => true);
        TodasLasOfertas = await specialOfferService.GetList(o => o.SpecialOfferId > 0);
    }

    private string ResolverRutaImagen(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
            return string.Empty;

        if (valor.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            valor.StartsWith("https://", StringComparison.OrdinalIgnoreCase) ||
            valor.StartsWith("/"))
        {
            return valor;
        }

        return $"/uploads/products/{valor}";
    }

    private Task PrevisualizarRuta()
    {
        if (string.IsNullOrWhiteSpace(RutaImagenManual))
        {
            toastService.ShowWarning("Escribe una URL o una ruta.");
            return Task.CompletedTask;
        }

        UrlImagenPreview = ResolverRutaImagen(RutaImagenManual.Trim());
        return Task.CompletedTask;
    }

    private Task GuardarRutaTemporal()
    {
        if (string.IsNullOrWhiteSpace(RutaImagenManual))
        {
            toastService.ShowWarning("Escribe una URL o una ruta.");
            return Task.CompletedTask;
        }

        RutaImagenParaGuardar = RutaImagenManual.Trim();
        UrlImagenPreview = ResolverRutaImagen(RutaImagenParaGuardar);
        toastService.ShowSuccess("Imagen preparada para guardar.");
        return Task.CompletedTask;
    }

    private void AgregarOferta()
    {
        if (OfertaSeleccionadaId == 0) return;

        var oferta = TodasLasOfertas.FirstOrDefault(o => o.SpecialOfferId == OfertaSeleccionadaId);
        if (oferta == null) return;

        if (OfertasSeleccionadas.Any(o => o.SpecialOfferId == OfertaSeleccionadaId))
        {
            toastService.ShowWarning("Esta oferta ya está en la lista.");
            return;
        }

        OfertasSeleccionadas.Add(oferta);
        OfertaSeleccionadaId = 0;
    }

    private void RemoverOferta(SpecialOffer oferta)
    {
        OfertasSeleccionadas.Remove(oferta);
    }

    public async Task Guardar()
    {
        Product.WeightUnitMeasureCode = string.IsNullOrWhiteSpace(Product.WeightUnitMeasureCode) ? null : Product.WeightUnitMeasureCode;
        Product.SizeUnitMeasureCode = string.IsNullOrWhiteSpace(Product.SizeUnitMeasureCode) ? null : Product.SizeUnitMeasureCode;
        Product.ProductLine = string.IsNullOrWhiteSpace(Product.ProductLine) ? null : Product.ProductLine;
        Product.Class = string.IsNullOrWhiteSpace(Product.Class) ? null : Product.Class;
        Product.Style = string.IsNullOrWhiteSpace(Product.Style) ? null : Product.Style;
        Product.ModifiedDate = DateTime.Now;

        var duplicado = await productService.GetList(p =>
            (p.Name.ToLower().Trim() == Product.Name.ToLower().Trim()
             || p.ProductNumber.ToLower().Trim() == Product.ProductNumber.ToLower().Trim())
            && p.ProductId != Product.ProductId);

        if (duplicado.Any())
        {
            toastService.ShowWarning("Ya existe otro producto con el mismo nombre o número de producto.");
            return;
        }

        bool guardado = await productService.Guardar(Product);

        if (!guardado)
        {
            toastService.ShowError("Ha ocurrido un error inesperado al guardar el producto.");
            return;
        }

        if (!string.IsNullOrWhiteSpace(RutaImagenParaGuardar))
        {
            await photoService.AsignarFotoPrincipal(Product.ProductId, RutaImagenParaGuardar);
        }

        foreach (var oferta in OfertasSeleccionadas)
        {
            await specialOfferProductService.Guardar(new SpecialOfferProduct
            {
                ProductId = Product.ProductId,
                SpecialOfferId = oferta.SpecialOfferId
            });
        }

        toastService.ShowSuccess("Producto creado exitosamente.");
        navigationManager.NavigateTo("/Product/Index");
    }
}