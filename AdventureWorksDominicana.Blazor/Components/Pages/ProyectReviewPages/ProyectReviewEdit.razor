@page "/product-reviews/edit/{Id:int}"
@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@inject ProductReviewService ProductReviewService
@inject NavigationManager navigationManager
@inject ToastService toastService
@rendermode InteractiveServer

<PageTitle>Editar Registro de Review</PageTitle>

<div class="bg-light border border-bottom-0 rounded-top py-2 px-3 mt-3 shadow-sm mx-2">
    <h5 class="mb-0 text-dark">Editar Registro de Review</h5>
</div>

<div class="bg-white border rounded-bottom shadow-sm mx-2 p-4">
    @if (review == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-2 text-muted small">Cargando información del review...</p>
        </div>
    }
    else
    {
        <EditForm Model="review" FormName="editarProductReview" OnValidSubmit="Actualizar">
            <DataAnnotationsValidator />
            
            <div class="row g-3">
                <div class="col-md-5 col-lg-4">
                    <label class="form-label fw-bold text-dark mb-1 small">ID del Producto</label>
                    <InputNumber @bind-Value="review.ProductId" class="form-control form-control-sm bg-light" disabled />
                </div>

                <div class="col-md-7 col-lg-8">
                    <label class="form-label fw-bold text-dark mb-1 small">Nombre del Revisor</label>
                    <InputText @bind-Value="review.ReviewerName" class="form-control form-control-sm" placeholder="Nombre completo" />
                    <ValidationMessage For="(() => review.ReviewerName)" class="text-danger small" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold text-dark mb-1 small">Email</label>
                    <InputText @bind-Value="review.EmailAddress" class="form-control form-control-sm" placeholder="correo@ejemplo.com" />
                    <ValidationMessage For="(() => review.EmailAddress)" class="text-danger small" />
                </div>

                <div class="col-md-6 col-lg-4">
                    <label class="form-label fw-bold text-dark mb-1 small">Calificaci&oacute;n (1-5)</label>
                    <InputNumber @bind-Value="review.Rating" class="form-control form-control-sm" min="1" max="5" />
                    <ValidationMessage For="(() => review.Rating)" class="text-danger small" />
                </div>

                <div class="col-12">
                    <label class="form-label fw-bold text-dark mb-1 small">Comentarios</label>
                    <InputTextArea @bind-Value="review.Comments" class="form-control form-control-sm" rows="3" placeholder="Sus comentarios..." />
                    <ValidationMessage For="(() => review.Comments)" class="text-danger small" />
                </div>
            </div>

            
            <div class="d-flex justify-content-center gap-2 mt-5">
                <button type="button" class="btn btn-secondary btn-sm px-3" @onclick="Volver">
                    <i class="bi bi-arrow-left"></i> Volver
                </button>
                
                
                <button type="submit" class="btn btn-primary btn-sm px-3">
                    <i class="bi bi-floppy"></i> Guardar
                </button>

                
                <button type="button" class="btn btn-danger btn-sm px-3" @onclick="EliminarRegistro">
                    <i class="bi bi-trash"></i> Eliminar
                </button>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    public ProductReview? review { get; set; }

    protected override async Task OnInitializedAsync()
    {
        review = await ProductReviewService.GetReviewByIdAsync(Id);
        if (review == null)
        {
            toastService.ShowError("El review no fue encontrado.");
            navigationManager.NavigateTo("/product-reviews");
        }
    }

    public async Task Actualizar()
    {
        if (review != null)
        {
            bool actualizado = await ProductReviewService.UpdateAsync(review);
            if (actualizado)
            {
                toastService.ShowSuccess("Review guardado exitosamente.");
                navigationManager.NavigateTo("/product-reviews");
            }
            else
            {
                toastService.ShowError("Error al intentar guardar el registro.");
            }
        }
    }

    private async Task EliminarRegistro()
    {
        if (review != null)
        {
            bool eliminado = await ProductReviewService.DeleteAsync(review.ProductReviewId);
            if (eliminado)
            {
                toastService.ShowSuccess("Review eliminado correctamente.");
                navigationManager.NavigateTo("/product-reviews");
            }
            else
            {
                toastService.ShowError("No se pudo eliminar el registro.");
            }
        }
    }

    private void Volver() => navigationManager.NavigateTo("/product-reviews");
}