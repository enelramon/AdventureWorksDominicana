@page "/product-reviews/edit/{Id:int}"
@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@inject ProductReviewService ProductReviewService
@inject NavigationManager navigationManager
@inject ToastService toastService
@rendermode InteractiveServer

<PageTitle>Editar Registro de Review</PageTitle>


<div class="bg-light border-bottom py-3 px-4 mb-4">
    <h3 class="mb-0 fs-5 text-dark">Editar Registro de Review</h3>
</div>

<div class="container-fluid px-4">
    @if (review == null)
    {
       
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-2 text-muted">Cargando información del review...</p>
        </div>
    }
    else
    {
        <EditForm Model="review" FormName="editarProductReview" OnValidSubmit="Actualizar">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger mb-4" />

            
            <div class="row g-3">
                
                <div class="col-md-6">
                    <label class="form-label fw-bold text-dark mb-1">ID del Producto</label>
                    <InputNumber @bind-Value="review.ProductId" class="form-control" disabled />
                </div>

               
                <div class="col-md-6">
                    <label class="form-label fw-bold text-dark mb-1">Nombre del Revisor</label>
                    <InputText @bind-Value="review.ReviewerName" class="form-control" placeholder="Nombre completo" />
                    <ValidationMessage For="(() => review.ReviewerName)" />
                </div>

               
                <div class="col-md-6">
                    <label class="form-label fw-bold text-dark mb-1">Email</label>
                    <InputText @bind-Value="review.EmailAddress" class="form-control" placeholder="correo@ejemplo.com" />
                    <ValidationMessage For="(() => review.EmailAddress)" />
                </div>

               
                <div class="col-md-6">
                    <label class="form-label fw-bold text-dark mb-1">Calificaci&oacute;n (1-5)</label>
                    <InputNumber @bind-Value="review.Rating" class="form-control" />
                    <ValidationMessage For="(() => review.Rating)" />
                </div>

                
                <div class="col-12">
                    <label class="form-label fw-bold text-dark mb-1">Comentarios</label>
                    <InputTextArea @bind-Value="review.Comments" class="form-control" rows="3" placeholder="Sus comentarios..." />
                    <ValidationMessage For="(() => review.Comments)" />
                </div>
            </div>

           
            <div class="d-flex justify-content-center gap-3 mt-5 pb-4">
                <button type="button" class="btn btn-secondary px-4 py-2" @onclick="Volver">
                    <i class="bi bi-arrow-left"></i> Volver
                </button>
                <button type="submit" class="btn btn-success px-4 py-2">
                    <i class="bi bi-floppy"></i> Modificar
                </button>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    public ProductReview? review { get; set; }

    protected override async Task OnInitializedAsync()
    {
        
        review = await ProductReviewService.GetReviewByIdAsync(Id);

        if (review == null)
        {
            toastService.ShowError("El review no fue encontrado.");
            navigationManager.NavigateTo("/product-reviews");
        }
    }

    public async Task Actualizar()
    {
        if (review != null)
        {
           
            bool actualizado = await ProductReviewService.UpdateAsync(review);
            
            if (actualizado)
            {
                toastService.ShowSuccess("Review modificado exitosamente.");
                navigationManager.NavigateTo("/product-reviews");
            }
            else
            {
                toastService.ShowError("Error al intentar modificar el registro.");
            }
        }
    }

    private void Volver() => navigationManager.NavigateTo("/product-reviews");
}