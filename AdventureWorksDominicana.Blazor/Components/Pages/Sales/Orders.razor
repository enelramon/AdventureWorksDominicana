@page "/Orders"

@rendermode InteractiveServer

@inject SalesOrderHeaderService salesOrderHeaderService
@inject NavigationManager navigationManager
@inject EmailAddressService emailAddressService
@inject AuthenticationStateProvider authenticationStateProvider;
@inject CustomerService customerService
@inject ToastService toastService

<PageTitle>Orders</PageTitle>

<div class="container">
    @* Boton de volver *@
    <span class="btn btn-outline-primary bi bi-arrow-left mb-2" @onclick="GoToSale"> Volver</span>

    <div class="card shadow-lg">
        @*Header*@
        <div class="card-header">
            <h3 class="card-title">Orders</h3>
        </div>
        <div class="card-body">
            @foreach (var s in SalesOrderHeadersList)
            {
                <div class="card order-card shadow border-1 mb-3 bg-light-subtle border-secondary-subtle">

                    <div class="card-body">

                        <!-- Top -->
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <small class="text-muted">
                                @(s.ShipDate?.ToString("dd MMM yyyy") ?? "Sin fecha")
                            </small>

                            <span class="badge @(s.Status == 1 ? "bg-warning text-dark" : "bg-danger")">
                                @(s.Status == 1 ? "En proceso" : "Cancelado")
                            </span>
                        </div>

                        <!-- Info -->
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-semibold">Orden #@s.SalesOrderId</div>
                                <small class="text-muted">Total</small>
                            </div>

                            <div class="fw-bold fs-5">
                                RD$ @s.TotalDue
                            </div>
                        </div>

                        <!-- Action -->
                        <div class="mt-3 text-end">
                            <button class="btn btn-sm btn-outline-primary bi bi-file-text" @onclick="() => GoToOrderReview(s.SalesOrderId)">
                                Ver detalles
                            </button>
                        </div>

                    </div>
                </div>
            }
        </div>
    </div>
</div>
@code {
    private List<SalesOrderHeader> SalesOrderHeadersList = new List<SalesOrderHeader>();

    private ClaimsPrincipal? User { get; set; }
    private bool IsAuthenticated { get; set; }
    private string? UserEmail { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // 1. Obtener usuario logueado
        var authState = await authenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true) return;

        var userEmail = user.FindFirst(ClaimTypes.Email)?.Value;
        if (string.IsNullOrEmpty(userEmail))
        {
            toastService.ShowError("Correo del usuario invalido");
            Console.WriteLine("\nEmail del usuario logeado es nulo\n");
            navigationManager.NavigateTo("/Sales/");
            return;
        }

        // 2. Buscar el email
        var email = await emailAddressService.BuscarPorEmail(userEmail);
        if (email == null)
        {
            toastService.ShowError("Correo no encontrado.");
            Console.WriteLine("\nEmail buscado es nulo\n");
            navigationManager.NavigateTo("/Sales/");
            return;
        }

        // 3. Obtener el CustomerID asociado a esa persona
        int customerId = await customerService.GetCustomerId(email.BusinessEntityId);
        
        // 4. Obtener órdenes de TODOS esos CustomerID
        SalesOrderHeadersList = await salesOrderHeaderService.GetList(s => s.CustomerId == customerId);
    }

    private void GoToSale() => navigationManager.NavigateTo("/Sales");

    private void GoToOrderReview(int saleId) => navigationManager.NavigateTo($"Order/Review/{saleId}");

}