@page "/ShipMethods"
@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@using Microsoft.AspNetCore.Components.QuickGrid

@inject ShipMethodService shipMethodService

<PageTitle>ShipMethods</PageTitle>
<div class="container">
    <div class="card shadow-lg">
        <div class="card-header bg-light d-flex justify-content-between">
            <h5 class="card-title">ShipMethods</h5>
        </div>
        <div class="card-body bg-light">
            <div class="mt-3 table-responsive">
                <QuickGrid TGridItem="ShipMethod" Items="@ListaQuery" class="table table-striped table-hover table-bordered">
                    <PropertyColumn Property="e => e.ShipMethodId" Title="Id" />
                    <PropertyColumn Property="e => e.Name" Title="Nombre" />
                    <PropertyColumn Property="e => e.ShipBase" Title="Costo base" />
                    <PropertyColumn Property="e => e.ShipRate" Title="Costo adicional" />
                    <PropertyColumn Property="e => e.ModifiedDate" Title="Fecha de modificacion" />
                    <TemplateColumn Title="Acciones">
                        <a class="btn btn-sm btn-outline-primary"
                           href="@($"/ShipMethods/Edit/{context.ShipMethodId}")">
                            <span class="bi bi-pencil-square"></span>
                        </a>
                    </TemplateColumn>
                </QuickGrid>
            </div>
        </div>
        <div class="card-footer bg-light d-flex justify-content-between">
            <label><strong>Cantidad:</strong> @ListaShipMethods.Count</label>
        </div>
    </div>
</div>

@code {
    public IQueryable<ShipMethod> ListaQuery = Enumerable.Empty<ShipMethod>().AsQueryable();
    public List<ShipMethod> ListaShipMethods = new List<ShipMethod>();

    protected override async Task OnInitializedAsync()
    {
        ListaShipMethods = await shipMethodService.Listar(criterio: e => e.ShipMethodId > 0);
        ListaQuery = ListaShipMethods.AsQueryable();
    }
}
