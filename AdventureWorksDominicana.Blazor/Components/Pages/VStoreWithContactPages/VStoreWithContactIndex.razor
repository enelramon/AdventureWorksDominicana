@page "/VStoreWithContact/Index"

@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@using Microsoft.AspNetCore.Components.QuickGrid
@inject VStoreWithContactService Service

<PageTitle>VStoreWithContact</PageTitle>

<div class="container mt-4">
    <div class="card shadow-lg">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">VStoreWithContact</h4>
        </div>

        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <label class="form-label fw-bold">Id</label>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Tienda</label>
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-bold">Contacto</label>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-3">
                    <InputNumber class="form-control" @bind-Value="filtroId" />
                </div>

                <div class="col-md-4">
                    <InputText class="form-control" @bind-Value="filtroTienda" />
                </div>

                <div class="col-md-5">
                    <InputText class="form-control" @bind-Value="filtroContacto" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-12 d-flex gap-2">
                    <button class="btn btn-primary w-100" @onclick="Buscar">
                        <i class="bi bi-search"></i> Buscar
                    </button>

                    <button class="btn btn-outline-primary w-100" @onclick="Reestablecer">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
            </div>

            <QuickGrid Items="lista.AsQueryable()" Class="table table-striped table-bordered table-hover">
                <PropertyColumn Property="@(x => x.BusinessEntityId)" Title="Id" />
                <PropertyColumn Property="@(x => x.Name)" Title="Tienda" />

                <TemplateColumn Title="Contacto">
                    <ChildContent Context="item">
                        @($"{item.FirstName} {item.LastName}".Trim())
                    </ChildContent>
                </TemplateColumn>

                <PropertyColumn Property="@(x => x.ContactType)" Title="Tipo" />
                <PropertyColumn Property="@(x => x.EmailAddress)" Title="Email" />
                <PropertyColumn Property="@(x => x.PhoneNumber)" Title="Teléfono" />
            </QuickGrid>
        </div>

        <div class="card-footer text-end fw-bold">
            @lista.Count item(s)
        </div>
    </div>
</div>

@code {
    private List<VStoreWithContact> lista = new();
    private int? filtroId;
    private string filtroTienda = string.Empty;
    private string filtroContacto = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    private async Task Cargar()
    {
        lista = await Service.Listar(x =>
            (!filtroId.HasValue || x.BusinessEntityId == filtroId.Value) &&
            (string.IsNullOrWhiteSpace(filtroTienda) || (x.Name ?? string.Empty).Contains(filtroTienda)) &&
            (string.IsNullOrWhiteSpace(filtroContacto) ||
             ($"{x.FirstName} {x.LastName}".Trim()).Contains(filtroContacto))
        );
    }

    private async Task Buscar() => await Cargar();

    private async Task Reestablecer()
    {
        filtroId = null;
        filtroTienda = string.Empty;
        filtroContacto = string.Empty;
        await Cargar();
    }
}