@page "/shipping-orders"
@using Microsoft.AspNetCore.Components.QuickGrid
@using AdventureWorksDominicana.Data.Models
@inject AdventureWorksDominicana.Services.ShippingService ShippingService
@inject NavigationManager Navigation

<div class="card shadow-lg">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Envíos</h4>
    </div>

    <div class="card-body">
        <div class="row g-3 mb-2">
            <div class="col-md-3">
                <label class="form-label fw-bold">Desde</label>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">Hasta</label>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">Buscar</label>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">&nbsp;</label>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <InputDate class="form-control" @bind-Value="FiltroDesde" />
            </div>
            <div class="col-md-3">
                <InputDate class="form-control" @bind-Value="FiltroHasta" />
            </div>
            <div class="col-md-3">
                <InputText class="form-control" @bind-Value="Busqueda" />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button class="btn btn-primary" @onclick="BuscarAsync">
                    <i class="bi bi-search"></i> Buscar
                </button>
                <button class="btn btn-outline-primary" @onclick="LimpiarAsync">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
        </div>

        <QuickGrid Items="@(orders.AsQueryable())" class="table table-striped table-bordered table-hover">
            <PropertyColumn Property="o => o.SalesOrderId" Title="Orden" />
            <PropertyColumn Property="o => o.OrderDate" Title="Fecha" />
            <PropertyColumn Property="o => o.TotalDue" Title="Total" />

            <TemplateColumn Title="Cliente">
                @GetCustomerName(context)
            </TemplateColumn>

            <TemplateColumn Title="Estado">
                @GetStatusText(context.Status)
            </TemplateColumn>

            <TemplateColumn Title="Acciones">
                <button class="btn btn-outline-primary btn-sm" @onclick="() => AbrirAsync(context.SalesOrderId)">
                    <i class="bi bi-pencil-square"></i> @(context.Status == 5 ? "Editar" : "Procesar")
                </button>
            </TemplateColumn>
        </QuickGrid>
    </div>

    <div class="card-footer text-end fw-bold">
        Total de registros: @orders.Count
    </div>
</div>

@code {
    private List<SalesOrderHeader> orders = new();
    private DateTime? FiltroDesde;
    private DateTime? FiltroHasta;
    private string? Busqueda;

    protected override async Task OnInitializedAsync()
    {
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        orders = await ShippingService.GetShippingOrdersAsync(FiltroDesde, FiltroHasta, Busqueda);
    }

    private async Task BuscarAsync()
    {
        await CargarAsync();
    }

    private async Task LimpiarAsync()
    {
        FiltroDesde = null;
        FiltroHasta = null;
        Busqueda = null;
        await CargarAsync();
    }

    private void AbrirAsync(int orderId)
    {
        Navigation.NavigateTo($"/shipping-process/{orderId}");
    }

    private static string GetCustomerName(SalesOrderHeader order)
    {
        var personName = order.Customer?.Person != null
            ? $"{order.Customer.Person.FirstName} {order.Customer.Person.LastName}".Trim()
            : string.Empty;

        if (!string.IsNullOrWhiteSpace(personName))
        {
            return personName;
        }

        return order.Customer?.Store?.Name ?? "N/A";
    }

    private static string GetStatusText(byte status)
    {
        return status switch
        {
            1 => "Pendiente",
            5 => "Enviado",
            _ => "Otro"
        };
    }
}