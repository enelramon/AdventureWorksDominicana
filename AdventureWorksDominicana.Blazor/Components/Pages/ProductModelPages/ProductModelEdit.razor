@page "/ProductModel/Edit/{Id:int}"
@attribute [Authorize(Roles = "Admin, ProductionManager")]
@using System.Xml.Serialization
@using System.Xml
@using System.IO
@inject NavigationManager navigationManager
@inject ToastService toastService
@inject ProductModelService modelService
@inject ProductDescriptionService descriptionService
@inject CultureService cultureService
@rendermode InteractiveServer

<PageTitle>Editar Modelo - AdventureWorks</PageTitle>

@if (model == null)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p>Cargando datos del modelo...</p>
    </div>
}
else
{
    <EditForm Model="model" OnValidSubmit="Guardar" FormName="EditProductModelForm">
        <DataAnnotationsValidator />

        <div class="container mt-4">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white shadow-sm">
                    <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Editar Modelo de Producto</h4>
                </div>

                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nombre del Modelo</label>
                        <InputText class="form-control" @bind-Value="model.Name" />
                        <ValidationMessage For="() => model.Name" />
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-info">Material (Catalog XML)</label>
                            <InputText class="form-control border-info" @bind-Value="catalogDto.Material" placeholder="Ej: Aluminum" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-info">Instrucciones (Instructions XML)</label>
                            <InputText class="form-control border-info" @bind-Value="instructionsDto.SetupSummary" placeholder="Ej: Inspect before use" />
                        </div>
                    </div>

                    @* Sección Maestro-Detalle *@
                    <div class="p-3 mb-3 bg-light rounded border">
                        <h5 class="mb-3 text-secondary">Descripciones por Idioma</h5>
                        <div class="row mb-3 g-2">
                            <div class="col-md-3">
                                <select class="form-select" @bind="nuevaCulturaId">
                                    <option value="">Seleccione Cultura...</option>
                                    @foreach (var c in ListaCulturas)
                                    {
                                        <option value="@c.CultureId">@c.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-7">
                                <InputTextArea class="form-control" rows="1" @bind-Value="nuevoTexto" placeholder="Nueva descripción comercial..." />
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-success w-100" @onclick="AgregarDetalle"> <i class="bi bi-plus-lg"></i></button>
                            </div>
                        </div>

                        <QuickGrid Items="model.ProductModelProductDescriptionCultures.AsQueryable()" Class="table table-sm table-hover border">
                            <PropertyColumn Property="x => x.CultureId" Title="Cultura" />
                            <TemplateColumn Title="Descripción">@context.ProductDescription?.Description</TemplateColumn>
                            <TemplateColumn Title="Acción" Class="text-center">
                                <button type="button" class="btn btn-outline-danger btn-sm" @onclick="(() => model.ProductModelProductDescriptionCultures.Remove(context))">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </TemplateColumn>
                        </QuickGrid>
                    </div>
                </div>

                <div class="card-footer bg-white border-top-0 text-center pb-4">
                    <hr />
                    <a class="btn btn-secondary px-4 me-2" href="/ProductModel/Index">Cancelar</a>
                    <button type="submit" class="btn btn-primary px-5 shadow">
                        <i class="bi bi-save"></i> Guardar Cambios
                    </button>
                </div>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }

    [SupplyParameterFromForm]
    private ProductModel? model { get; set; }

    private List<Culture> ListaCulturas = new();
    private string nuevaCulturaId = "", nuevoTexto = "";
    private CatalogDto catalogDto = new();
    private InstructionsDto instructionsDto = new();

    protected override async Task OnInitializedAsync()
    {
        ListaCulturas = await cultureService.GetList(c => true);
        
        if (model == null)
        {
            model = await modelService.Buscar(Id);
            if (model != null)
            {
                catalogDto = DeserializarDesdeXml<CatalogDto>(model.CatalogDescription) ?? new();
                instructionsDto = DeserializarDesdeXml<InstructionsDto>(model.Instructions) ?? new();
            }
        }
    }

    // --- SERIALIZACIÓN MANUAL "A PRUEBA DE BALAS" ---
    private string? SerializarAXml<T>(T objeto)
    {
        if (objeto == null) return null;

        try
        {
            if (objeto is CatalogDto c && !string.IsNullOrWhiteSpace(c.Material))
            {
                // Genera el XML exacto que AdventureWorks pide para CatalogDescription
                return $"<ProductDescription xmlns=\"http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription\"><Material>{c.Material}</Material></ProductDescription>";
            }

            if (objeto is InstructionsDto i && !string.IsNullOrWhiteSpace(i.SetupSummary))
            {
                // Genera el XML exacto para Instructions
                return $"<root xmlns=\"http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelInstructions\"><Instructions>{i.SetupSummary}</Instructions></root>";
            }
        }
        catch { return null; }

        return null;
    }

    private T? DeserializarDesdeXml<T>(string? xml) where T : class
    {
        if (string.IsNullOrWhiteSpace(xml)) return null;
        try
        {
            var serializer = new XmlSerializer(typeof(T));
            using var reader = new StringReader(xml);
            return (T?)serializer.Deserialize(reader);
        }
        catch { return null; }
    }

    private async Task Guardar()
    {
        if (model == null) return;

        // Convertimos los DTOs a los strings XML limpios
        model.CatalogDescription = SerializarAXml(catalogDto);
        model.Instructions = SerializarAXml(instructionsDto);
        model.ModifiedDate = DateTime.Now;

        if (await modelService.Guardar(model))
        {
            toastService.ShowSuccess("Cambios aplicados correctamente.");
            navigationManager.NavigateTo("/ProductModel/Index");
        }
        else
        {
            toastService.ShowError("Error al guardar en la base de datos.");
        }
    }

    private async Task AgregarDetalle()
    {
        if (string.IsNullOrWhiteSpace(nuevaCulturaId) || string.IsNullOrWhiteSpace(nuevoTexto)) return;
        
        var pDesc = new ProductDescription
        {
            Description = nuevoTexto,
            ModifiedDate = DateTime.Now,
            Rowguid = Guid.NewGuid()
        };

        if (await descriptionService.Guardar(pDesc))
        {
            model!.ProductModelProductDescriptionCultures.Add(new ProductModelProductDescriptionCulture
            {
                CultureId = nuevaCulturaId,
                ProductDescriptionId = pDesc.ProductDescriptionId,
                ProductDescription = pDesc
            });
            nuevoTexto = "";
            toastService.ShowInfo("Traducción agregada localmente.");
        }
    }

    // --- DTOS SIMPLES ---
    // Usamos etiquetas XmlElement para que la deserialización siga funcionando al cargar datos
    [XmlRoot(ElementName = "ProductDescription", Namespace = "http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelDescription")]
    public class CatalogDto { [XmlElement] public string Material { get; set; } = ""; }

    [XmlRoot(ElementName = "root", Namespace = "http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/ProductModelInstructions")]
    public class InstructionsDto { [XmlElement(ElementName = "Instructions")] public string SetupSummary { get; set; } = ""; }
}