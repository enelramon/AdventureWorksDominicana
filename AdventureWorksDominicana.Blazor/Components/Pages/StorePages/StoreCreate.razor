@page "/Store/Create"
@attribute [Authorize(Roles = "ProductionManager, Admin")]
@using System.Xml.Serialization
@using System.IO
@using Microsoft.EntityFrameworkCore;
@using AdventureWorksDominicana.Data.Context;
@using AdventureWorksDominicana.Data.Models;

@inject StoreService storeService;
@inject ToastService toastService;
@inject NavigationManager navigationManager;
@inject Contexto contexto

<EditForm Model="Store" FormName="crearStore" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />

    <div class="container">
        <div class="card">
            <div class="card-header text-center">
                <h4>Crear Store</h4>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label"><strong>Nombre</strong></label>
                    <input class="form-control" type="text" maxlength="50" @bind-value="Store.Name" placeholder="Escriba el nombre..." />
                    <ValidationMessage For="(() => Store.Name)" />
                </div>

                <div class="mb-3">
                    <label class="form-label"><strong>Sales Person</strong></label>
                    <InputSelect class="form-select" @bind-Value="Store.SalesPersonId">
                        <option value="" disabled selected hidden>Seleccione un sales person...</option>
                        <option value="">Ninguno</option>
                        @foreach (var sp in ListaSalesPerson)
                        {
                            <option value="@sp.BusinessEntityId">ID @sp.BusinessEntityId</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="(() => Store.SalesPersonId)" />
                </div>

                @* --- CAMBIAR TEXTAREA POR INPUTS VINCULADOS A DTOs --- *@
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label"><strong>Ventas Anuales</strong></label>
                        <InputNumber class="form-control" @bind-Value="demographicsDto.AnnualSales" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><strong>Nombre del Banco</strong></label>
                        <InputText class="form-control" @bind-Value="demographicsDto.BankName" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label"><strong>Año de Apertura</strong></label>
                        <InputNumber class="form-control" @bind-Value="demographicsDto.YearOpened" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><strong>Cantidad de Empleados</strong></label>
                        <InputNumber class="form-control" @bind-Value="demographicsDto.NumberEmployees" />
                    </div>
                </div>
            </div>

            <div class="card-footer text-center">
                <a class="btn btn-secondary bi bi-arrow-left" href="/Store/Index"> Volver</a>
                <button class="btn btn-primary bi bi-floppy" type="submit"> Guardar</button>
            </div>
        </div>
    </div>
</EditForm>

@code {
    public Store Store { get; set; } = new Store();
    public List<SalesPerson> ListaSalesPerson { get; set; } = new();

    @* --- INSTANCIAR LOS DTOS --- *@
    private StoreDemographicsDto demographicsDto = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ListaSalesPerson = await contexto.SalesPeople.OrderBy(s => s.BusinessEntityId).ToListAsync();
        }
        catch (Exception)
        {
            toastService.ShowError("Ha ocurrido un error al cargar la lista de Sales Person.");
            ListaSalesPerson = new List<SalesPerson>();
        }
    }

    @* --- FUNCIÓN PARA CONVERTIR DTO A XML --- *@
    private string SerializarAXml<T>(T objeto)
    {
        if (objeto == null) return string.Empty;
        try
        {
            var serializer = new XmlSerializer(typeof(T));
            using (var sw = new StringWriter())
            {
                serializer.Serialize(sw, objeto);
                return sw.ToString();
            }
        }
        catch { return string.Empty; }
    }

    public async Task Guardar()
    {
        if (Store.SalesPersonId.HasValue && Store.SalesPersonId.Value > 0)
        {
            Store.SalesPerson = ListaSalesPerson.FirstOrDefault(sp => sp.BusinessEntityId == Store.SalesPersonId.Value);
        }
        else
        {
            toastService.ShowError("El campo sales person no puede estar vacio. Seleccione una ocion valida");
            return;
        }

        Store.ModifiedDate = DateTime.Now;

        try
        {
            bool guardado = await storeService.Guardar(Store);
            if (guardado)
            {
                toastService.ShowSuccess("La tienda se ha guardado correctamente.");
                navigationManager.NavigateTo("/Store/Index");
            }
            else
            {
                toastService.ShowError("No se pudo guardar la tienda.");
            }
        }catch(Exception e)
        {
            toastService.ShowError("Ha ocurrido un error inesperado. Favor verifique los campos antes de guardar.");
            Console.WriteLine(e.Message);
        }

    } 
    @* --- DEFINIR LAS CLASES DTO AL FINAL --- *@
    public class StoreDemographicsDto
    {
        public decimal AnnualSales { get; set; }
        public string BankName { get; set; } = "";
        public int YearOpened { get; set; }
        public int NumberEmployees { get; set; }
    }
}
