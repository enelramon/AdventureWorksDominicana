@page "/Store/Edit/{Id:int}"
@attribute [Authorize(Roles = "ProductionManager, Admin")]
@using Microsoft.EntityFrameworkCore;
@using AdventureWorksDominicana.Data.Context;
@using AdventureWorksDominicana.Data.Models;
@using AdventureWorksDominicana.Data.Models.DTOs;
@using AdventureWorksDominicana.Blazor.Helpers;
@rendermode InteractiveServer

@inject StoreService storeService;
@inject ToastService toastService;
@inject NavigationManager navigationManager;
@inject Contexto contexto

<div class="store-edit-container">

    <!-- HEADER -->
    <div class="store-edit-header">
        <div>
            <h3>Editar Store</h3>
            <span>Modificación de tienda existente</span>
        </div>
    </div>

    <!-- FORM -->
    <div class="store-edit-form">
        <EditForm Model="Store" FormName="editarStore" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card shadow-lg">
                <div class="card-body">

                    <!-- SECCIÓN GENERAL -->
                    <h5 class="section-title">
                        <i class="bi bi-shop"></i> Información General
                    </h5>

                    <!-- ID -->
                    <div class="mb-3">
                        <label class="form-label">
                            <strong>ID</strong>
                        </label>
                        <input class="form-control" value="@Store.BusinessEntityId" disabled />
                    </div>

                    <!-- NOMBRE -->
                    <div class="mb-3">
                        <label class="form-label">
                            <strong>Nombre</strong>
                        </label>
                        <input class="form-control"
                               type="text"
                               maxlength="50"
                               @bind-value="Store.Name"
                               placeholder="Escriba el nombre..." />
                        <ValidationMessage For="(() => Store.Name)" />
                    </div>

                    <!-- SALES PERSON -->
                    <div class="mb-3">
                        <label class="form-label">
                            <strong>Sales Person</strong>
                        </label>
                        <InputSelect class="form-select" @bind-Value="Store.SalesPersonId">
                            <option value="">Seleccione...</option>
                            @foreach (var sp in ListaSalesPerson)
                            {
                                <option value="@sp.BusinessEntityId">
                                    ID @sp.BusinessEntityId
                                </option>
                            }
                        </InputSelect>
                        <ValidationMessage For="(() => Store.SalesPersonId)" />
                    </div>

                    <!-- DEMOGRAPHICS (reemplazando el textarea de XML) -->
                    <h5 class="section-title mt-4">
                        <i class="bi bi-bar-chart"></i> Información Demográfica
                    </h5>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label"><strong>Ventas Anuales ($)</strong></label>
                            <InputNumber class="form-control" @bind-Value="demographicsDto.AnnualSales" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><strong>Nombre del Banco</strong></label>
                            <InputText class="form-control" @bind-Value="demographicsDto.BankName" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label"><strong>Año de Apertura</strong></label>
                            <InputNumber class="form-control" @bind-Value="demographicsDto.YearOpened" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><strong>Cantidad de Empleados</strong></label>
                            <InputNumber class="form-control" @bind-Value="demographicsDto.NumberEmployees" />
                        </div>
                    </div>

                </div>

                <!-- FOOTER -->
                <div class="card-footer text-center">
                    <a class="btn btn-secondary bi bi-arrow-left" href="/Store/Index">
                        Volver
                    </a>
                    <button class="btn btn-primary bi bi-floppy" type="submit">
                        Guardar
                    </button>
                    <button class="btn btn-danger bi bi-trash" type="button" @onclick="Eliminar">
                        Eliminar
                    </button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    public Store Store { get; set; } = new Store();
    public List<SalesPerson> ListaSalesPerson { get; set; } = new();
    private StoreDemographicsDto demographicsDto = new();

    protected override async Task OnInitializedAsync()
    {
        var store = await storeService.Buscar(Id);
        if (store != null)
        {
            Store = store;
            // Igual que en ProductModelEdit: cargamos el XML existente al DTO
            // para que el usuario vea los datos actuales en las cajitas normales
            demographicsDto = XmlHelper.DeserializarDesdeXml<StoreDemographicsDto>(Store.Demographics) ?? new();
        }

        try
        {
            ListaSalesPerson = await contexto.SalesPeople.OrderBy(s => s.BusinessEntityId).ToListAsync();
        }
        catch (Exception)
        {
            toastService.ShowError("Ha ocurrido un error al cargar la lista de Sales Person.");
            ListaSalesPerson = new List<SalesPerson>();
        }
    }

    public async Task Guardar()
    {
        if (Store.SalesPersonId.HasValue && Store.SalesPersonId.Value > 0)
        {
            Store.SalesPerson = ListaSalesPerson.FirstOrDefault(sp => sp.BusinessEntityId == Store.SalesPersonId.Value);
        }
        else
        {
            toastService.ShowError("El campo Sales Person no puede estar vacío. Seleccione una opción válida.");
            return;
        }

        // Convertimos el DTO a XML antes de guardar
        Store.Demographics = XmlHelper.SerializarAXml(demographicsDto);
        Store.ModifiedDate = DateTime.Now;

        try
        {
            bool guardado = await storeService.Guardar(Store);
            if (guardado)
            {
                toastService.ShowSuccess("La tienda se ha guardado correctamente.");
                navigationManager.NavigateTo("/Store/Index");
            }
            else
            {
                toastService.ShowError("No se pudo guardar la tienda.");
            }
        }
        catch (Exception ex)
        {
            toastService.ShowError($"Error al guardar: {ex.Message}");
            if (ex.InnerException != null)
            {
                toastService.ShowError($"Detalle técnico: {ex.InnerException.Message}");
                Console.WriteLine(ex.InnerException.Message);
            }
        }
    }

    private async Task Eliminar()
    {
        try
        {
            var eliminado = await storeService.Eliminar(Store.BusinessEntityId);
            if (eliminado)
            {
                toastService.ShowSuccess("La tienda ha sido eliminada con éxito.");
                navigationManager.NavigateTo("/Store/Index");
            }
            else
            {
                toastService.ShowError("No se pudo eliminar la tienda.");
            }
        }
        catch (Exception ex)
        {
            toastService.ShowError(ex.Message);
        }
    }
}