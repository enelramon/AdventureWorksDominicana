@page "/AddressType/Index"
@rendermode InteractiveServer
@inject AddressTypeService AddressTypeService

<PageTitle>AddressType</PageTitle>

<div class="container">
    <div class="card shadow-lg">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title text-black mb-0">Registro de Tipos de Dirección</h5>
            <a href="AddressType/Create" class="btn btn-primary">
                <i class="bi bi-plus-square"></i> Crear
            </a>
        </div>

        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <label class="form-label">Desde</label>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Hasta</label>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Filtrar por</label>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Buscar</label>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3">
                    <input class="form-control" type="date" @bind="Desde" />
                </div>
                <div class="col-md-3">
                    <input class="form-control" type="date" @bind="Hasta" />
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="Filtro">
                        <option value="">Seleccione una opci&oacute;n</option>
                        <option value="Nombre">Nombre</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="input-group">
                        <input class="form-control" type="text" placeholder="Buscar..." @bind="ValorFiltro" />
                        <button class="btn btn-primary" type="button" @onclick="Buscar">
                            <i class="bi bi-search"></i>
                        </button>
                        <button class="btn btn-outline-primary" type="button" @onclick="Restablecer">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                    </div>
                </div>
            </div>

            <div class="table-responsive mt-3">
                <QuickGrid Items="ListaAddressType.AsQueryable()" Pagination="@pages" Class="table table-striped table-bordered table-hover align-middle">
                    <PropertyColumn Property="@(a => a.AddressTypeId)" Title="ID" Sortable="true" />
                    <PropertyColumn Property="@(a => a.Name)" Title="Nombre" Sortable="true" />
                    <PropertyColumn Property="@(a => a.ModifiedDate)" Title="Fecha Modificación" Format="dd/MM/yyyy" Sortable="true" />
                    <TemplateColumn Context="option" Title="Opción">
                        <a href="AddressType/Edit/@option.AddressTypeId" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-pencil"></i> Modificar
                        </a>
                    </TemplateColumn>
                </QuickGrid>
                <Paginator State="@pages" />
            </div>
        </div>

        <div class="card-footer text-end">
            <strong>Total de registros: @ListaAddressType.Count</strong>
        </div>
    </div>
</div>

@code {
    private List<AddressType> ListaAddressType = new List<AddressType>();
    private PaginationState pages = new PaginationState { ItemsPerPage = 5 };

    private string Filtro = string.Empty;
    private string ValorFiltro = string.Empty;
    private DateTime? Desde;
    private DateTime? Hasta;

    protected override async Task OnInitializedAsync()
    {
        await CargarTodo();
    }

    private async Task CargarTodo()
    {
        ListaAddressType = await AddressTypeService.GetList(a => true);
    }

    private async Task Buscar()
    {
        ListaAddressType = await AddressTypeService.GetList(a =>
            (!Desde.HasValue || a.ModifiedDate >= Desde.Value.Date) &&
            (!Hasta.HasValue || a.ModifiedDate <= Hasta.Value.Date.AddDays(1).AddTicks(-1)) &&
            (string.IsNullOrWhiteSpace(ValorFiltro) ||
                (Filtro == "Nombre" && a.Name.Contains(ValorFiltro)) ||
                (string.IsNullOrWhiteSpace(Filtro) && a.Name.Contains(ValorFiltro))
            )
        );
    }

    private async Task Restablecer()
    {
        Filtro = string.Empty;
        ValorFiltro = string.Empty;
        Desde = null;
        Hasta = null;
        await CargarTodo();
    }
}