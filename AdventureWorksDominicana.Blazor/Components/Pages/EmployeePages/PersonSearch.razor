@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@using Microsoft.AspNetCore.Components

@inject PersonService personService

<div class="mb-3">
    <input type="text"
           class="form-control"
           placeholder="Escriba nombre o apellido..."
           @bind="nombre"
           @bind:event="oninput"
           @bind:after="BuscarPersonas" />
</div>

@if (resultados.Any())
{
    <div class="list-group mt-2">
        @foreach (var persona in resultados)
        {
            <button type="button"
                    class="list-group-item list-group-item-action"
                    @onclick="() => SeleccionarPersona(persona)">
                <strong>@($"{persona.FirstName} {persona.LastName}".Trim())</strong>
                <small class="text-muted d-block">ID: @persona.BusinessEntityId</small>
            </button>
        }
    </div>
}

@if (personaSeleccionada != null)
{
    <div class="alert alert-success mt-3">
        <strong>Persona seleccionada:</strong>
        @($"{personaSeleccionada.FirstName} {personaSeleccionada.LastName}".Trim())
        (Id: @personaSeleccionada.BusinessEntityId)

        <button class="btn btn-sm btn-link" type="button" @onclick="LimpiarSeleccion">
            [Cambiar]
        </button>
    </div>
}

@code {
    [Parameter]
    public int? PersonaId { get; set; }

    [Parameter]
    public EventCallback<int?> PersonaIdChanged { get; set; }

    private string nombre = string.Empty;
    private List<Person> resultados = new();
    private Person? personaSeleccionada;

    protected override async Task OnInitializedAsync()
    {
        if (PersonaId.HasValue)
        {
            var persona = await personService.Buscar(PersonaId.Value);
            if (persona != null)
            {
                SeleccionarPersona(persona);
            }
        }
    }

    private async Task BuscarPersonas()
    {
        if (string.IsNullOrWhiteSpace(nombre))
        {
            resultados.Clear();
            personaSeleccionada = null;
            return;
        }

        resultados = await personService.BuscarPorNombre(nombre);
    }

    private async Task SeleccionarPersona(Person persona)
    {
        personaSeleccionada = persona;
        nombre = $"{persona.FirstName ?? ""} {persona.LastName ?? ""}".Trim();
        resultados.Clear();

        PersonaId = persona.BusinessEntityId;
        await PersonaIdChanged.InvokeAsync(PersonaId);
    }

    private async Task LimpiarSeleccion()
    {
        personaSeleccionada = null;
        nombre = string.Empty;
        resultados.Clear();
        PersonaId = null;

        await PersonaIdChanged.InvokeAsync(null);
    }
}