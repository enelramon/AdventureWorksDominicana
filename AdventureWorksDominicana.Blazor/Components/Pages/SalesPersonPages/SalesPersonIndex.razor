@page "/sales-people"
@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@using Microsoft.AspNetCore.Components.QuickGrid
@inject SalesPersonService SalesPersonService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Registro de Vendedores</PageTitle>

<div class="container-fluid">
    <div class="card shadow-lg">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">Registro de Vendedores</h5>
            <button class="btn btn-primary btn-sm px-4" @onclick="IrACrear">
                <i class="bi bi-plus-square"></i> Crear
            </button>
        </div>

        <div class="card-body">
            
            <div class="row"><div class="col-md-4"><label><strong>Buscar por ID o Territorio:</strong></label></div></div>
            <div class="row mb-4">
                <div class="col-md-4">
                    <input type="text" class="form-control" placeholder="Ej: 274..." @bind="textoBusqueda" />
                </div>
                <div class="col-md-8 d-flex gap-2">
                    <button class="btn btn-primary" @onclick="AplicarFiltro"><i class="bi bi-search"></i> Buscar</button>
                    <button class="btn btn-outline-primary" @onclick="LimpiarBusqueda"><i class="bi bi-arrow-clockwise"></i> Limpiar</button>
                </div>
            </div>

            @if (vendedores != null)
            {
                <div class="table-responsive">
                    <QuickGrid Items="@FilteredSalesPeople" Pagination="@paginacion" Class="table table-striped table-bordered table-hover">
                        <PropertyColumn Property="@(p => p.BusinessEntityId)" Title="ID" Sortable="true" />
                        <TemplateColumn Title="Vendedor">
                            @{
                                var p = context.BusinessEntity?.BusinessEntity;
                                <span>@(p != null ? $"{p.FirstName} {p.LastName}" : "N/A")</span> 
                            }
                        </TemplateColumn>
                        <PropertyColumn Property="@(p => p.SalesYtd)" Title="Ventas YTD" Format="C2" Sortable="true" />
                        <TemplateColumn Title="Opciones" Class="text-center">
                            <button class="btn btn-outline-primary btn-sm" @onclick="() => IrAEditar(context.BusinessEntityId)">
                                <i class="bi bi-pencil-square"></i> Modificar
                            </button>
                        </TemplateColumn>
                    </QuickGrid>
                </div>
                <Paginator State="@paginacion" />
            }
        </div>
        <div class="card-footer text-end bg-white">
            <strong>Registros: @(FilteredSalesPeople?.Count() ?? 0)</strong>
        </div>
    </div>
</div>

@code {
    private List<SalesPerson>? vendedores;
    private string textoBusqueda = "";
    private IQueryable<SalesPerson>? filteredList;
    PaginationState paginacion = new PaginationState { ItemsPerPage = 5 };

    protected override async Task OnInitializedAsync()
    {
        vendedores = await SalesPersonService.GetSalesPeopleAsync();
        AplicarFiltro();
    }

    private IQueryable<SalesPerson> FilteredSalesPeople => filteredList ?? Enumerable.Empty<SalesPerson>().AsQueryable();

    private void AplicarFiltro()
    {
        if (vendedores == null) return;
        var query = vendedores.AsQueryable();
        if (!string.IsNullOrWhiteSpace(textoBusqueda))
        {
            query = query.Where(s => s.BusinessEntityId.ToString().Contains(textoBusqueda) ||
                (s.Territory != null && s.Territory.Name.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)));
        }
        filteredList = query;
    }
    private void LimpiarBusqueda() { textoBusqueda = ""; AplicarFiltro(); }
    private void IrACrear() => NavigationManager.NavigateTo("/sales-people/create");
    private void IrAEditar(int id) => NavigationManager.NavigateTo($"/sales-people/edit/{id}");
}