@page "/Payroll/Details/{PayrollId:int}"
@attribute [Authorize(Roles = "Admin,HRManager")]

@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services

@inject PayrollService payrollService
@inject ToastService toastService
@inject NavigationManager navigationManager
@rendermode InteractiveServer

<PageTitle>Detalle de N&oacute;mina</PageTitle>

<div class="container mt-4 mb-5">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-dark text-white p-4 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 fw-bold"><i class="bi bi-file-earmark-spreadsheet me-2"></i>N&oacute;mina #@PayrollId</h4>
            <div class="btn-group shadow-sm">
                @if (Nomina != null && Nomina.Status == PayrollStatus.Borrador)
                {
                    <button class="btn btn-warning fw-bold" @onclick="AprobarNomina">
                        <i class="bi bi-check-circle me-1"></i> Aprobar
                    </button>
                }
                else if (Nomina != null && Nomina.Status == PayrollStatus.Aprobada)
                {
                    <button class="btn btn-success fw-bold" @onclick="PagarNomina">
                        <i class="bi bi-cash-coin me-1"></i> Registrar Pago
                    </button>
                }
    
                <a class="btn btn-outline-light" href="/Payroll/Index">Volver</a>
            </div>
        </div>
        
        @if (Nomina == null)
        {
            <div class="card-body text-center p-5">
                <div class="spinner-border text-primary"></div>
                <p class="mt-3">Cargando volante...</p>
            </div>
        }
        else
        {
            <div class="card-body p-5">
                <div class="row border-bottom pb-4 mb-4">
                    <div class="col-6">
                        <h2 class="fw-bold text-uppercase">AdventureWorks</h2>
                        <p class="text-muted mb-0">RNC: 1-01-00000-1</p>
                        <p class="text-muted">Rep&uacute;blica Dominicana</p>
                    </div>
                    <div class="col-6 text-end">
                        <h4 class="fw-bold">REPORTE DE PAGO</h4>
                        <div class="badge bg-success px-3 py-2">@Nomina.Status.ToString().ToUpper()</div>
                    </div>
                </div>

                <div class="row mb-5 gy-3">
                    <div class="col-md-5">
                        <span class="text-muted small fw-bold text-uppercase d-block">Descripci&oacute;n</span>
                        <span class="fs-5 fw-bold">@Nomina.Description</span>
                    </div>
                    <div class="col-md-3">
                        <span class="text-muted small fw-bold text-uppercase d-block">Per&iacute;odo</span>
                        <span>@Nomina.PeriodStartDate.ToString("dd/MM/yyyy") - @Nomina.PeriodEndDate.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="col-md-2">
                        <span class="text-muted small fw-bold text-uppercase d-block">Creaci&oacute;n</span>
                        <span>@Nomina.CreatedDate.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="col-md-2 text-md-end">
                        <span class="text-muted small fw-bold text-uppercase d-block">Fecha Pago</span>
                        @if (Nomina.PaymentDate.HasValue)
                        {
                            <span class="text-success fw-bold"><i class="bi bi-check2-all"></i> @Nomina.PaymentDate.Value.ToString("dd/MM/yyyy")</span>
                        }
                        else
                        {
                            <span class="text-muted fst-italic">Pendiente</span>
                        }
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead class="table-light text-uppercase small fw-bold">
                            <tr>
                                <th>Empleado</th>
                                <th class="text-end">Sueldo Bruto</th>
                                <th class="text-end text-danger">SFS</th>
                                <th class="text-end text-danger">AFP</th>
                                <th class="text-end text-danger">ISR</th>
                                <th class="text-end fw-bold">Sueldo Neto</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var det in Nomina.PayrollDetails)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold">@det.Employee?.BusinessEntity?.FirstName @det.Employee?.BusinessEntity?.LastName</div>
                                        <small class="text-muted">Código: #@det.BusinessEntityId</small>
                                    </td>
                                    <td class="text-end fw-bold">RD$ @det.GrossSalary.ToString("N2")</td>
                                    <td class="text-end text-danger">(@det.SfsDeduction.ToString("N2"))</td>
                                    <td class="text-end text-danger">(@det.AfpDeduction.ToString("N2"))</td>
                                    <td class="text-end text-danger">(@det.IsrDeduction.ToString("N2"))</td>
                                    <td class="text-end fw-bold text-success bg-light">RD$ @det.NetSalary.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-dark fs-5">
                            <tr>
                                <td colspan="5" class="text-end fw-bold">TOTAL GENERAL RD$</td>
                                <td class="text-end fw-bold">@Nomina.PayrollDetails.Sum(d => d.NetSalary).ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int PayrollId { get; set; }
    private Payroll? Nomina;

    protected override async Task OnInitializedAsync()
    {
        Nomina = await payrollService.Buscar(PayrollId);
        if (Nomina == null)
        {
            navigationManager.NavigateTo("/Payroll/Index");
        }
    }

    private async Task AprobarNomina()
    {
        Nomina!.Status = PayrollStatus.Aprobada;
        var exito = await payrollService.Guardar(Nomina);
        if (exito) toastService.ShowSuccess("Nómina aprobada y lista para pago.");
        else toastService.ShowError("Error aprobando nómina.");
    }

    private async Task PagarNomina()
    {
        try
        {
            if (Nomina == null)
            {
                navigationManager.NavigateTo("/Payroll/Index");
                return;
            }
            Nomina.Status = PayrollStatus.Pagada;
            Nomina.PaymentDate = DateTime.Now;
            
            await payrollService.Guardar(Nomina);
            toastService.ShowSuccess("El pago ha sido registrado en el sistema.");
        }
        catch (Exception ex)
        {
            toastService.ShowError("Error al procesar el pago: " + ex.Message);
        }
    }
}