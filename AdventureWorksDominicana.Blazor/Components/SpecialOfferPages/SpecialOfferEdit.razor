@page "/specialoffer/edit/{Id:int}"

@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@inject SpecialOfferService SpecialOfferService
@inject NavigationManager Navigation

<PageTitle>Editar SpecialOffer</PageTitle>

@if (model == null)
{
    <p>Cargando...</p>
}
else
{
    <div class="container mt-4">
        <div class="card shadow-lg">

            <div class="card-header">
                <h4 class="mb-0">Editar SpecialOffer</h4>
            </div>

            <EditForm Model="model" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />

                <div class="card-body">

                    <div class="mb-3">
                        <label class="form-label fw-bold">Id</label>
                        <InputNumber class="form-control" @bind-Value="model.SpecialOfferId" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Descripción</label>
                        <InputText class="form-control" @bind-Value="model.Description" />
                        <ValidationMessage For="() => model.Description" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Descuento</label>
                        <InputNumber class="form-control" @bind-Value="model.DiscountPct" />
                        <ValidationMessage For="() => model.DiscountPct" />
                    </div>

                </div>

                <div class="card-footer text-center">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-floppy"></i> Modificar
                    </button>

                    <button type="button" class="btn btn-secondary" @onclick="Volver">
                        <i class="bi bi-arrow-left"></i> Volver
                    </button>
                </div>

            </EditForm>

        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private SpecialOffer? model;

    protected override async Task OnParametersSetAsync()
    {
        model = await SpecialOfferService.Buscar(Id);
    }

    private async Task Guardar()
    {
        await SpecialOfferService.Guardar(model!);
        Navigation.NavigateTo("/specialoffer");
    }

    private void Volver() => Navigation.NavigateTo("/specialoffer");
}