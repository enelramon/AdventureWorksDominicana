@page "/specialoffer/consulta"
@using AdventureWorksDominicana.Data.Models
@using AdventureWorksDominicana.Services
@inject SpecialOfferService SpecialOfferService
@inject NavigationManager Navigation
@inject Blazored.Toast.Services.IToastService ToastService

<PageTitle>Consulta de SpecialOffer</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1">Consulta de SpecialOffer</h3>
            <p class="text-muted mb-0">Listado y administración de ofertas especiales.</p>
        </div>

        <button class="btn btn-primary" @onclick="Nuevo">
            <i class="bi bi-plus-circle"></i> Nuevo
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label class="form-label">Id</label>
                    <InputNumber class="form-control" @bind-Value="filtroId" />
                </div>

                <div class="col-md-5">
                    <label class="form-label">Descripción</label>
                    <InputText class="form-control" @bind-Value="filtroDescripcion" />
                </div>

                <div class="col-md-4 d-flex align-items-end gap-2">
                    <button class="btn btn-primary w-100" @onclick="Buscar">
                        <i class="bi bi-search"></i> Buscar
                    </button>

                    <button class="btn btn-outline-secondary w-100" @onclick="Limpiar">
                        <i class="bi bi-eraser"></i> Limpiar
                    </button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Id</th>
                            <th>Descripción</th>
                            <th>Descuento %</th>
                            <th>Tipo</th>
                            <th>Categoría</th>
                            <th>Inicio</th>
                            <th>Fin</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (lista.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    No hay registros para mostrar.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in lista)
                            {
                                <tr>
                                    <td>@item.SpecialOfferId</td>
                                    <td>@item.Description</td>
                                    <td>@item.DiscountPct</td>
                                    <td>@item.Type</td>
                                    <td>@item.Category</td>
                                    <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                                    <td>@item.EndDate.ToString("yyyy-MM-dd")</td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => Editar(item.SpecialOfferId)">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>

                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(item.SpecialOfferId)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3 text-muted">
                Cantidad: @lista.Count
            </div>
        </div>
    </div>
</div>

@code {
    private List<SpecialOffer> lista = [];
    private int? filtroId;
    private string filtroDescripcion = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        lista = await SpecialOfferService.Listar(s =>
            (!filtroId.HasValue || s.SpecialOfferId == filtroId.Value) &&
            (string.IsNullOrWhiteSpace(filtroDescripcion) || (s.Description ?? string.Empty).Contains(filtroDescripcion)));
    }

    private async Task Buscar()
    {
        await CargarDatos();
    }

    private async Task Limpiar()
    {
        filtroId = null;
        filtroDescripcion = string.Empty;
        await CargarDatos();
    }

    private void Nuevo()
    {
        Navigation.NavigateTo("/specialoffer/registro");
    }

    private void Editar(int id)
    {
        Navigation.NavigateTo($"/specialoffer/registro/{id}");
    }

    private async Task Eliminar(int id)
    {
        var eliminado = await SpecialOfferService.Eliminar(id);

        if (eliminado)
        {
            ToastService.ShowSuccess("Registro eliminado correctamente.");
            await CargarDatos();
        }
        else
        {
            ToastService.ShowError("No se pudo eliminar el registro.");
        }
    }
}